PORT=5000
NODE_ENV=development

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Exact Vercel URL(s) — no trailing slash. Comma-separated for multiple.
# Local: http://localhost:5173 | Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Optional: allow any https://*.vercel.app preview deployment
ALLOW_VERCEL_PREVIEWS=false

# When FRONTEND_URL is a *.vercel.app URL, any other *.vercel.app origin is allowed by default.
# Set ALLOW_ANY_VERCEL=false to disable that behavior.
